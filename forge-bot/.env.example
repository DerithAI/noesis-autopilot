# EVO-Bot Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# OLLAMA (Required)
# =============================================================================
OLLAMA_HOST=127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b

# =============================================================================
# TELEGRAM BOT (Optional - for Telegram integration)
# =============================================================================
# 1. Talk to @BotFather on Telegram
# 2. Send /newbot
# 3. Choose name and username
# 4. Copy the token here:
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Comma-separated list of allowed Telegram user IDs (empty = allow all)
# Get your ID by messaging @userinfobot on Telegram
TELEGRAM_ALLOWED_USERS=123456789,987654321

# =============================================================================
# WOLF_AI (Optional - auto-detected if WOLF_AI installed)
# =============================================================================
WOLF_ROOT=C:\Users\Main\WOLF_AI

# =============================================================================
# IMPULSE/LUMENA (Optional - auto-detected if installed)
# =============================================================================
# IMPULSE_ROOT=F:\MANUS_PROJECT\LUMEN_MEGA_PLATFORM\TEMP_DOWNLOADS\IMPULSE_UNPACK\IMPULSE-20.0.0-singularity
